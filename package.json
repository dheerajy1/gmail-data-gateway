{
  "name": "gmail-data-gateway",
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "bunx tailwindcss -i ./src/tailwind.css -o ./public/global.css && bun --hot src/server.ts",
    "build": "bun run clean && bunx tailwindcss -i ./src/tailwind.css -o ./public/global.css && tsc && tsc-alias && cp -r public dist/public",
    "start": "NODE_ENV=production bun dist/server.js",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "clean": "rm -rf dist/* dist/.* || true",
    "db:test": "bun scripts/db-select-test.ts",
    "token:gen": "bun src/lib/generate-token.ts",
    "token:getexpat": "bun scripts/get-token-expiry.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.0",
    "@elysiajs/openapi": "^1.4.14",
    "@elysiajs/static": "^1.4.7",
    "elysia": "^1.4.22",
    "googleapis": "^171.4.0",
    "lucide-react": "^0.564.0",
    "mssql": "^12.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ws": "^8.19.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/cli": "^4.1.18",
    "@types/bun": "1.3.1",
    "@types/mssql": "^9.1.8",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "semantic-release": "^25.0.2",
    "tailwindcss": "^4.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "5.8.3"
  }
}